<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="501.0" prefWidth="362.0" spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sample.AppointmentViewController">
    <children>
        <Label layoutX="65.0" layoutY="14.0" text="APPOINTMENT INFO">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        <GridPane prefHeight="395.0" prefWidth="322.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="275.0" minWidth="10.0" prefWidth="112.0" />
                <ColumnConstraints fillWidth="false" hgrow="SOMETIMES" maxWidth="472.0" minWidth="10.0" prefWidth="210.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Appointment ID" />
                <Label text="Title" GridPane.rowIndex="1" />
                <Label prefHeight="17.0" prefWidth="116.0" text="Description" GridPane.rowIndex="2" />
                <Label text="Location" GridPane.rowIndex="3" />
                <Label text="Type" GridPane.rowIndex="4" />
                <Label text="Date" GridPane.rowIndex="5" />
                <Label text="Start Time" GridPane.rowIndex="6" />
                <Label text="End Time" GridPane.rowIndex="7" />
                <TextField fx:id="appointmentIDTextField" disable="true" editable="false" prefHeight="25.0" prefWidth="62.0" GridPane.columnIndex="1" />
                <TextField fx:id="titleTextField" prefHeight="25.0" prefWidth="264.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="descriptionTextField" prefHeight="25.0" prefWidth="278.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="locationTextField" prefHeight="25.0" prefWidth="310.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="typeTextField" prefHeight="25.0" prefWidth="290.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <DatePicker fx:id="startDatePicker" editable="false" prefHeight="25.0" prefWidth="301.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label text="Customer" GridPane.rowIndex="8" />
            <Label text="Contact" GridPane.rowIndex="9" />
            <ChoiceBox fx:id="customerChoiceBox" prefHeight="25.0" prefWidth="247.0" GridPane.columnIndex="1" GridPane.rowIndex="8" />
            <ChoiceBox fx:id="contactChoiceBox" prefHeight="25.0" prefWidth="224.0" GridPane.columnIndex="1" GridPane.rowIndex="9" />
            <Label text="User" GridPane.rowIndex="10" />
            <ChoiceBox fx:id="userChoiceBox" prefHeight="25.0" prefWidth="229.0" GridPane.columnIndex="1" GridPane.rowIndex="10" />
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="6">
               <children>
                  <TextField fx:id="startTimeTextField" prefHeight="25.0" prefWidth="60.0" />
                  <Label text="HH:mm (24hr)" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="7">
               <children>
                  <TextField fx:id="endTimeTextField" prefHeight="25.0" prefWidth="60.0" />
                  <Label text="HH:mm (24hr)" />
               </children>
            </HBox>
            </children>
        </GridPane>
        <HBox prefHeight="3.0" prefWidth="322.0" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#saveButtonPressed" text="SAVE" />
                <Button mnemonicParsing="false" onAction="#cancelButtonPressed" text="CANCEL" />
            </children>
        </HBox>
    </children>
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
