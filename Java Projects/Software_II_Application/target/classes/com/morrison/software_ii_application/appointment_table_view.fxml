<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="841.0" prefWidth="1174.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.morrison.software_ii_application.AppointmentTableViewController">
   <children>
      <VBox prefHeight="334.0" prefWidth="1047.0" spacing="20.0">
         <children>
            <Label text="Customers">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <TableView fx:id="customerTable" prefHeight="244.0" prefWidth="1047.0">
              <columns>
                <TableColumn fx:id="customerIDColumn" prefWidth="94.0" text="Customer ID" />
                <TableColumn fx:id="nameColumn" prefWidth="239.0" text="Name" />
                  <TableColumn fx:id="addressColumn" prefWidth="413.0" text="Address" />
                  <TableColumn fx:id="postalCodeColumn" prefWidth="160.0" text="Postal Code" />
                  <TableColumn fx:id="phoneColumn" prefWidth="140.0" text="Phone" />
              </columns>
            </TableView>
            <HBox prefHeight="0.0" prefWidth="1047.0" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#addCustomerButtonPressed" text="Add" />
                  <Button mnemonicParsing="false" onAction="#editCustomerButtonPressed" text="Edit" />
                  <Button mnemonicParsing="false" onAction="#deleteCustomerButtonPressed" text="Delete" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" />
         </padding>
      </VBox>
      <VBox prefHeight="406.0" prefWidth="1047.0" spacing="20.0">
         <children>
            <Label text="Appointment Calender">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <TableView fx:id="appointmentTable" prefHeight="334.0" prefWidth="1047.0">
              <columns>
                <TableColumn fx:id="appointmentIDColumn" prefWidth="99.0" text="Appointment ID" />
                <TableColumn fx:id="titleColumn" prefWidth="99.0" text="Title" />
                  <TableColumn fx:id="descriptionColumn" prefWidth="112.0" text="Description" />
                  <TableColumn fx:id="locationColumn" prefWidth="115.0" text="Location" />
                  <TableColumn fx:id="typeColumn" prefWidth="89.0" text="Type" />
                  <TableColumn fx:id="startDateColumn" prefWidth="153.0" text="Start" />
                  <TableColumn fx:id="endDateColumn" prefWidth="164.0" text="End" />
                  <TableColumn fx:id="appointmentCustomerIDColumn" prefWidth="92.0" text="Customer ID" />
                  <TableColumn fx:id="userIDColumn" prefWidth="121.0" text="User ID" />
                  <TableColumn fx:id="contactIDColumn" prefWidth="89.0" text="Contact ID" />
              </columns>
            </TableView>
            <HBox prefHeight="0.0" prefWidth="1047.0" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#newAppointmentButtonPressed" text="New Appointment" />
                  <Button mnemonicParsing="false" onAction="#modifyAppointmentButtonPressed" text="Modify Appointment" />
               </children>
            </HBox>
            <HBox prefHeight="0.0" prefWidth="1047.0" />
         </children>
      </VBox>
      <Button mnemonicParsing="false" onAction="#logoutButtonPressed" text="Logout" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
