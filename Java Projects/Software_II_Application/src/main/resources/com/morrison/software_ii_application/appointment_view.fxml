            <Label text="Title" GridPane.rowIndex="1" />
            <Label prefHeight="17.0" prefWidth="74.0" text="Description" GridPane.rowIndex="2" />
            <Label text="Location" GridPane.rowIndex="3" />
            <Label text="Type" GridPane.rowIndex="4" />
            <Label text="Start Date" GridPane.rowIndex="5" />
            <Label text="Start Time" GridPane.rowIndex="6" />
            <Label text="End Date" GridPane.rowIndex="7" />
            <Label text="End Time" GridPane.rowIndex="8" />
            <TextField fx:id="appointmentIDTextField" disable="true" editable="false" prefHeight="25.0" prefWidth="62.0" GridPane.columnIndex="1" />
            <TextField fx:id="titleTextField" prefHeight="25.0" prefWidth="264.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="descriptionTextField" prefHeight="25.0" prefWidth="278.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <TextField fx:id="locationTextField" prefHeight="25.0" prefWidth="310.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <TextField fx:id="typeTextField" prefHeight="25.0" prefWidth="290.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <DatePicker fx:id="startDatePicker" prefHeight="25.0" prefWidth="301.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <HBox alignment="CENTER_LEFT" prefHeight="0.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="6">
               <children>
                  <ChoiceBox fx:id="startHourChoiceBox" prefHeight="25.0" prefWidth="45.0" />
                  <Label prefHeight="25.0" prefWidth="15.0" text=" : ">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
