      </GridPane>
      <HBox prefHeight="3.0" prefWidth="322.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#saveButtonPressed" text="Save" />
            <Button mnemonicParsing="false" onAction="#cancelButtonPressed" text="Cancel" />
